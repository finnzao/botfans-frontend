FROM python:3.12-slim

WORKDIR /app

RUN apt-get update && \
    apt-get install -y --no-install-recommends gcc libpq-dev && \
    rm -rf /var/lib/apt/lists/*

COPY src/worker/requirements.txt ./
RUN pip install --no-cache-dir -r requirements.txt

COPY src/worker/ ./

RUN mkdir -p logs

ENV PYTHONUNBUFFERED=1

CMD ["python", "main.py"]
